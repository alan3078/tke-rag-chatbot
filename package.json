{
  "name": "tke-rag-chatbot",
  "version": "1.0.0",
  "private": true,
  "description": "RAG chatbot for Tsinghua School of Software website corpus",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "crawl": "ts-node -P tsconfig.json --swc scripts/crawl.ts",
    "ingest": "ts-node -P tsconfig.json --swc scripts/ingest.ts",
    "check-coverage": "ts-node -P tsconfig.json --swc scripts/check-coverage.ts",
    "migration:run": "ts-node -P tsconfig.json --swc apps/web/lib/run-migrations.ts",
    "migration:generate": "TS_NODE_PROJECT=tsconfig.json typeorm-ts-node-commonjs migration:generate -d apps/web/lib/data-source.ts apps/web/migrations/Migration",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
