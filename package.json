{
  "name": "tke-rag-chatbot",
  "version": "1.0.0",
  "private": true,
  "description": "RAG chatbot for Tsinghua School of Software website corpus",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:backend": "npm run start:dev -w apps/backend",
    "build": "npm run build -w apps/backend && npm run build -w apps/web",
    "build:backend": "npm run build -w apps/backend",
    "build:frontend": "npm run build -w apps/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w apps/web",
    "typecheck:backend": "cd apps/backend && tsc --noEmit",
    "crawl": "npx tsx apps/backend/scripts/crawl.ts",
    "ingest": "npx tsx apps/backend/scripts/ingest.ts",
    "check-coverage": "npx tsx apps/backend/scripts/check-coverage.ts",
    "migration:run": "npx tsx apps/backend/src/database/run-migrations.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "vitest run --config apps/backend/vitest.config.ts",
    "test:backend:e2e": "npm run build -w apps/backend && vitest run --config apps/backend/vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
