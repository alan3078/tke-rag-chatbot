# =============================================================================
# TKE RAG Chatbot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
# API STRATEGY (ADR-0006):
#   - LLM (chat):      OpenRouter → DeepSeek V4 Pro
#   - Embeddings:      Ollama local → qwen3-embedding:4b (1024 dims, 100+ langs)
#
# OpenAI and Claude APIs are BLOCKED from the Beijing server.
# Run embeddings locally via Ollama, pg_dump the DB, restore on server.
# The server only needs LLM API access (OpenRouter) at runtime.
# =============================================================================

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tke_rag"

# --- LLM API (OpenRouter — DeepSeek) ---
LLM_API_KEY="sk-or-v1-your-openrouter-key"
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="deepseek/deepseek-v4-pro"
# Alternatives:
#   deepseek/deepseek-v4-flash     — $0.09/$0.18 per 1M tokens (cheapest)
#   deepseek/deepseek-chat         — $0.20/$0.80 per 1M tokens (v3 stable)
#   deepseek/deepseek-v3.2         — $0.23/$0.34 per 1M tokens
#   deepseek/deepseek-r1-0528      — $0.50/$2.15 per 1M tokens (reasoning)

# --- Embedding (Ollama local — qwen3-embedding:4b) ---
# Prerequisites: install Ollama, then run: ollama pull qwen3-embedding:4b
OLLAMA_BASE_URL="http://localhost:11434"
EMBEDDING_MODEL="qwen3-embedding:4b"
EMBEDDING_DIMENSIONS="1024"

# --- Retrieval Tuning (optional — defaults shown) ---
# RETRIEVAL_VECTOR_WEIGHT="0.6"
# RETRIEVAL_KEYWORD_WEIGHT="0.4"
# RETRIEVAL_TOP_K="8"
# RETRIEVAL_L1_BOOST="1.3"

# --- Authentication ---
AUTH_USERNAME="admin"
AUTH_PASSWORD="tke2026"
AUTH_SECRET="change-this-to-a-random-32-char-string"

# --- Crawler (optional overrides) ---
CRAWL_DELAY_MS="1000"
CRAWL_USER_AGENT="TKE-RAG-Challenge-Bot/1.0 AlanYiu contact:corgiking2020@gmail.com"

# --- Next.js ---
NEXT_PUBLIC_URL="http://localhost:3000"
