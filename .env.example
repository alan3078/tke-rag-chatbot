# =============================================================================
# TKE RAG Chatbot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
# API STRATEGY:
#   - LLM (chat):      OpenRouter → DeepSeek V4 Pro
#   - Embeddings:       SiliconFlow → BAAI/bge-m3 (free tier)
#   - Fallback embed:   Ollama local → bge-m3 (M1 Pro, offline)
#
# OpenAI and Claude APIs are BLOCKED from the Beijing server (123.59.90.15).
# OpenRouter and SiliconFlow are accessible from China.
# Alternatively, run embeddings locally on M1 Pro and pg_dump the DB to server.
# =============================================================================

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tke_rag"

# --- LLM API (OpenRouter — DeepSeek) ---
LLM_API_KEY="sk-or-v1-your-openrouter-key"
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="deepseek/deepseek-v4-pro"
# Alternatives:
#   deepseek/deepseek-v4-flash     — $0.09/$0.18 per 1M tokens (cheapest)
#   deepseek/deepseek-chat         — $0.20/$0.80 per 1M tokens (v3 stable)
#   deepseek/deepseek-v3.2         — $0.23/$0.34 per 1M tokens
#   deepseek/deepseek-r1-0528      — $0.50/$2.15 per 1M tokens (reasoning)

# --- Embedding API (SiliconFlow — BGE-M3, FREE) ---
EMBEDDING_API_KEY="sk-your-siliconflow-key"
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL="BAAI/bge-m3"
EMBEDDING_DIMENSIONS="1024"
# Alternatives:
#   Pro/BAAI/bge-m3                — ¥0.07/1M tokens (higher rate limits)
#   BAAI/bge-large-zh-v1.5         — Free (Chinese only, 512 max tokens)
#
# LOCAL FALLBACK (Ollama on M1 Pro):
#   EMBEDDING_BASE_URL="http://localhost:11434/v1"
#   EMBEDDING_API_KEY="ollama"
#   EMBEDDING_MODEL="bge-m3"

# --- Authentication ---
AUTH_USERNAME="admin"
AUTH_PASSWORD="tke2026"
AUTH_SECRET="change-this-to-a-random-32-char-string"

# --- Crawler (optional overrides) ---
CRAWL_DELAY_MS="1000"
CRAWL_USER_AGENT="TKE-RAG-Challenge-Bot/1.0 AlanYiu contact:corgiking2020@gmail.com"

# --- Next.js ---
NEXT_PUBLIC_URL="http://localhost:3000"
